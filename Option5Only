double ReadThermoC()
{
    uint16_t data = 0;

    digitalWrite(MAX_CS_PIN, LOW);
    delayMicroseconds(10);

    for (int i = 15; i >= 0; i--)
    {
        digitalWrite(MAX_CLK_PIN, LOW);
        delayMicroseconds(10);

        if (digitalRead(MAX_SO_PIN) == HIGH)
{
    uint16_t value = 1;

    for (int j = 0; j < i; j++)
    {
        value = value * 2;
    }

    data = data + value;
}

        digitalWrite(MAX_CLK_PIN, HIGH);
        delayMicroseconds(10);
    }

    digitalWrite(MAX_CS_PIN, HIGH);

    data = data / 8;
    data = data % 4096;

    return data * 0.25;
}

